{
    "name": "playwright-interceptor-repo",
    "version": "1.0.0",
    "author": "Martin Tichovsky",
    "description": "",
    "devDependencies": {
        "@eslint/js": "10.0.1",
        "@playwright/test": "1.61.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@types/node": "24.13.2",
        "c8": "11.0.0",
        "eslint": "10.4.1",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.6",
        "eslint-plugin-simple-import-sort": "13.0.0",
        "jiti": "2.7.0",
        "prettier": "3.8.3",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "typescript-eslint": "8.60.1"
    },
    "engines": {
        "node": ">=20.19.0"
    },
    "license": "MIT",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/MartinTichovsky/playwright-interceptor.git"
    },
    "scripts": {
        "build": "npm run build -w playwright-interceptor",
        "clean": "npm run clean --workspaces --if-present && rimraf  --glob \"**/tsconfig.build.tsbuildinfo\" \"**/tsconfig.*tsbuildinfo\"",
        "clean:node_modules": "rimraf --glob ./**/node_modules",
        "lint": "npm run lint --workspaces",
        "lint:fix": "npm run lint --workspaces -- --fix",
        "pw:install": "npm run pw:install -w playwright-interceptor-tests-latest",
        "server": "npm run start -w playwright-interceptor-server",
        "test": "npm run test -w playwright-interceptor-tests-latest",
        "test:coverage": "npm run build:coverage -w playwright-interceptor && c8 playwright test --config packages/playwright-latest/playwright.config.ts --tsconfig packages/playwright-latest/tsconfig.coverage.json --workers=1",
        "tsc": "npm run tsc --workspaces"
    },
    "workspaces": [
        "packages/*"
    ]
}
